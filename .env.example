# OpenAI — required for AI food analysis
OPENAI_API_KEY=sk-...

# PostgreSQL database URL — use Neon (vercel.com/integrations/neon) or any Postgres provider
# Leave unset to use SQLite locally
DATABASE_URL=postgresql://user:password@host/dbname

# Vercel Blob — required for photo uploads in production
# Create a Blob store at vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
